<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Doctor Appointment System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; }
        #wrapper { display: flex; align-items: stretch; }
        #sidebar { min-width: 250px; max-width: 250px; background: #2c3e50; color: #fff; min-height: 100vh; transition: all 0.3s; }
        #sidebar .sidebar-header { padding: 20px; background: #1a252f; text-align: center; font-weight: bold; font-size: 1.2rem; }
        #sidebar ul.components { padding: 20px 0; border-bottom: 1px solid #47748b; }
        #sidebar ul li a { padding: 15px 25px; font-size: 1.1em; display: block; color: #bdc3c7; text-decoration: none; }
        #sidebar ul li a:hover { color: #fff; background: #34495e; }
        #sidebar ul li.active > a { color: #fff; background: #3498db; }
        #content { width: 100%; padding: 20px; }
        .navbar { background: #fff; border: none; border-radius: 0; box-shadow: 1px 1px 3px rgba(0,0,0,0.1); }
        .card { border: none; border-radius: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.05); }
    </style>
</head>
<body>

    <div id="wrapper">
        <nav id="sidebar">
            <div class="sidebar-header">
                <i class="fa-solid fa-hospital-user me-2"></i> CareSoft v1.0
            </div>

            <ul class="list-unstyled components">
                <li class="@(ViewContext.RouteData.Values["Action"].ToString() == "Dashboard" ? "active" : "")">
                    <a href="@Url.Action("Index", "Home")"><i class="fa fa-home me-2"></i> Dashboard</a>
                </li>

                @* Role Based Menu Logic *@
                @if (User.IsInRole("Receptionist"))
                {
                    <li>
                        <a href="#"><i class="fa fa-user-plus me-2"></i> Register Patient</a>
                    </li>
                    <li>
                        <a href="#"><i class="fa fa-calendar-check me-2"></i> Book Appointment</a>
                    </li>
                }

                @if (User.IsInRole("Doctor"))
                {
                    <li>
                        <a href="#"><i class="fa fa- calendar-list me-2"></i> My Appointments</a>
                    </li>
                    <li>
                        <a href="#"><i class="fa fa-user-md me-2"></i> Patient History</a>
                    </li>
                }

                <li>
                    <a href="#"><i class="fa fa-cog me-2"></i> Settings</a>
                </li>
            </ul>
        </nav>

        <div id="content">
            <nav class="navbar navbar-expand-lg navbar-light">
                <div class="container-fluid">
                    <button type="button" id="sidebarCollapse" class="btn btn-info text-white">
                        <i class="fas fa-align-left"></i>
                    </button>
                    <div class="ms-auto">
                        <span class="me-3 text-secondary">Welcome, <strong>@User.Identity.Name</strong></span>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm">Logout</a>
                    </div>
                </div>
            </nav>

            <main role="main" class="container-fluid mt-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    <script>
        $(document).ready(function () {
            // Sidebar Toggle
            $('#sidebarCollapse').on('click', function () {
                $('#sidebar').toggleClass('active');
            });

            // Initialize Select2 (Aapki bind2select library ki jagah ye industry standard hai)
            $('.select2').select2({
                placeholder: "Select an option",
                allowClear: true,
                width: '100%'
            });

            // Initialize Date-Time Picker
            $(".datetimepicker").flatpickr({
                enableTime: true,
                dateFormat: "Y-m-d H:i",
                minDate: "today"
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>