@{
    Layout = "_Layout";
}

@using QuickCare.Areas.Receptionist.Controllers.ViewModals
@model PatientViewModal
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">Register Patients</h2>
    <button class="btn btn-primary rounded-circle shadow" onclick="openModal()">
        <i class="fas fa-plus"></i>
    </button>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <div class="input-group shadow-sm">
            <input type="text" id="searchInput" class="form-control" placeholder="Search by name or phone...">
            <button class="btn btn-info text-white" onclick="resetAndSearch()"><i class="fa fa-search"></i></button>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead class="bg-light">
                <tr>
                    <th>Full Name</th>
                    <th>Gender</th>
                    <th>Phone</th>
                    <th>City</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody id="patientTableBody">
                </tbody>
        </table>
    </div>
    <div id="shimmerContainer" style="display:none;">
        @await Html.PartialAsync("_PartialShimmer")
    </div>
</div>

@await Html.PartialAsync("_PatientModal", Model.Patient)

@section Scripts {
    <script>
        let page = 1;
        let isLoading = false;
        let isFullLoaded = false;

        $(document).ready(function() {
            loadPatients();

            $(window).scroll(function() {
                if ($(window).scrollTop() + $(window).height() >= $(document).height() - 100) {
                    if (!isLoading && !isFullLoaded) loadPatients();
                }
            });
        });

        function loadPatients() {
            isLoading = true;
            $("#shimmerContainer").show();
            $.get(`/Receptionist/Patients/GetPatientList?search=${$('#searchInput').val()}&page=${page}`, function(data) {
                if (data.trim() === "") {
                    isFullLoaded = true;
                } else {
                    $("#patientTableBody").append(data);
                    page++;
                }
                $("#shimmerContainer").hide();
                isLoading = false;
            });
        }

        function resetAndSearch() {
            $("#patientTableBody").empty();
            page = 1;
            isFullLoaded = false;
            loadPatients();
        }
    </script>
}