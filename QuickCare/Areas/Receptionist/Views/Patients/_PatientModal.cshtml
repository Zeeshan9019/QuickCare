@model QuickCare.Areas.Receptionist.Controllers.ViewModals.PatientVM

<div class="modal fade" id="patientModal" tabindex="-1" aria-labelledby="patientModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="patientModalLabel">
                    <i class="fas fa-user-medical me-2"></i> Patient Information
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="patientForm">
                <div class="modal-body p-4">
                    @Html.HiddenFor(m => m.PatientId)

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="Enter Full Name" required />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Gender</label>
                            <select asp-for="Gender" class="form-select select2-no-search">
                                <option value="1">Male</option>
                                <option value="2">Female</option>
                                <option value="3">Other</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Date of Birth</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa fa-calendar"></i></span>
                                <input asp-for="DateOfBirth" type="text" class="form-control flatpickr-date" placeholder="YYYY-MM-DD" />
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="03xx-xxxxxxx" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Email Address</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="example@mail.com" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">City</label>
                            <select asp-for="CityId" class="form-select select2-city" id="CityId">
                                <option value="">Select City</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Blood Group</label>
                            <select asp-for="BloodGroupId" class="form-select select2-blood" id="BloodGroupId">
                                <option value="">Select Blood Group</option>
                            </select>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold">Address</label>
                            <textarea asp-for="Address" class="form-control" rows="2" placeholder="Complete residential address"></textarea>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-danger">Allergies</label>
                            <textarea asp-for="Allergies" class="form-control" rows="2" placeholder="Any known allergies..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Medical History</label>
                            <textarea asp-for="MedicalHistory" class="form-control" rows="2" placeholder="Previous conditions..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm" id="btnSavePatient">
                        <i class="fas fa-save me-1"></i> Save Patient
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center p-4">
                <i class="fas fa-exclamation-triangle fa-3x text-danger mb-3"></i>
                <h5 class="fw-bold">Are you sure?</h5>
                <p class="text-muted">Ye patient record deactivate kar diya jayega.</p>
                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">No</button>
                    <button type="button" class="btn btn-danger" id="btnConfirmDelete">Yes, Delete</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        // Initialize Datepicker
        $(".flatpickr-date").flatpickr({
            dateFormat: "Y-m-d",
            maxDate: "today"
        });

        // Initialize Select2 for City & Blood Group
        $('.select2-city, .select2-blood').select2({
            dropdownParent: $('#patientModal'), // Modal ke andar dropdown sahi chale isliye
            width: '100%',
            placeholder: "Search & Select"
        });

        // Form Submit
        $('#patientForm').on('submit', function (e) {
            e.preventDefault();
            var formData = $(this).serialize();

            $.post('/Receptionist/Patients/SavePatient', formData, function (res) {
                if (res.success) {
                    $('#patientModal').modal('hide');
                    alert("Patient saved successfully!");
                    resetAndSearch(); // List refresh karne ke liye
                }
            });
        });
    });

    function openModal() {
        $('#patientForm')[0].reset();
        $('#PatientId').val(0);
        $('#patientModalLabel').text("Register New Patient");
        $('#patientModal').modal('show');
    }

    function editPatient(id) {
        // Yahan aap AJAX se data la kar form fill karenge
        $.get('/Receptionist/Patients/GetPatientById/' + id, function (data) {
            $('#PatientId').val(data.patientId);
            $('#FullName').val(data.fullName);
            $('#Gender').val(data.gender).trigger('change');
            $('#DateOfBirth').val(data.dateOfBirth.split('T')[0]);
            $('#PhoneNumber').val(data.phoneNumber);
            $('#Email').val(data.email);
            $('#Address').val(data.address);
            $('#CityId').val(data.cityId).trigger('change');
            $('#BloodGroupId').val(data.bloodGroupId).trigger('change');
            $('#Allergies').val(data.allergies);
            $('#MedicalHistory').val(data.medicalHistory);

            $('#patientModalLabel').text("Edit Patient Details");
            $('#patientModal').modal('show');
        });
    }

    var deleteId = 0;
    function confirmDelete(id) {
        deleteId = id;
        $('#deleteModal').modal('show');
    }

    $('#btnConfirmDelete').click(function() {
        $.post('/Receptionist/Patients/DeletePatient', { id: deleteId }, function(res) {
            if(res.success) {
                $('#deleteModal').modal('hide');
                resetAndSearch();
            }
        });
    });
</script>